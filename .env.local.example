# Cohortix — Local Development Environment
# ─────────────────────────────────────────
# Copy this file to .env.local and fill in your personal dev credentials.
# NEVER commit .env.local to git.
#
# Source: Supabase local project OR shared dev project
# Auth:   Clerk development instance (pk_test_ / sk_test_)

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Use Supabase transaction pooler for serverless compatibility (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Use direct connection for Drizzle migrations (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Supabase API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.[your-service-role-key]

# ── Authentication (Clerk — Dev Instance) ────────────────────────────────────
# Use TEST keys (pk_test_ / sk_test_) for local development
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_[your-clerk-publishable-key]
CLERK_SECRET_KEY=sk_test_[your-clerk-secret-key]
CLERK_WEBHOOK_SECRET=whsec_[your-webhook-secret]
NEXT_PUBLIC_CLERK_DOMAIN=localhost

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Auth bypass for local testing ONLY — never set true in staging/prod
BYPASS_AUTH=false

# ── Redis / Rate Limiting (Upstash — Optional for local) ────────────────────
# Leave blank to disable rate limiting locally
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Background Jobs (Inngest — Optional for local) ───────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Monitoring (Sentry — Optional for local) ─────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── AI/LLM APIs (Optional) ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
