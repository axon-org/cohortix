# Cohortix — Production Environment Variables
# ─────────────────────────────────────────────
# These vars live in Vercel → Project Settings → Environment Variables
# scoped to the "Production" environment (mapped to the `main` branch).
#
# ⚠️  LIVE SYSTEM — Handle with extreme care.
# Store secrets only in Vercel / GitHub Actions environments (never in git).

# ── Database (Supabase — Production Project) ─────────────────────────────────
# Get these from: Supabase Dashboard → cohortix-production project → Settings → Database
DATABASE_URL=postgresql://postgres.qobvewyakovekbuvwjkt:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.qobvewyakovekbuvwjkt:[password]@db.qobvewyakovekbuvwjkt.supabase.co:5432/postgres

# ── Supabase API (Production Project) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://qobvewyakovekbuvwjkt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.[prod-anon-key]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.[prod-service-role-key]

# ── Authentication (Clerk — Cohortix app, Prod instance) ──────────────────────
# Use LIVE keys (pk_live_ / sk_live_) — real user-facing credentials
# Get from: Clerk Dashboard → Cohortix app → Prod instance → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_[prod-clerk-publishable-key]
CLERK_SECRET_KEY=sk_live_[prod-clerk-secret-key]
CLERK_WEBHOOK_SECRET=whsec_[prod-webhook-secret]

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.cohortix.ai
NODE_ENV=production
BYPASS_AUTH=false

# ── Redis / Rate Limiting (Upstash — Production DB) ─────────────────────────
UPSTASH_REDIS_REST_URL=https://[prod-redis-endpoint].upstash.io
UPSTASH_REDIS_REST_TOKEN=[prod-redis-token]

# ── Background Jobs (Inngest — Production Branch) ────────────────────────────
INNGEST_EVENT_KEY=[prod-inngest-event-key]
INNGEST_SIGNING_KEY=[prod-inngest-signing-key]

# ── Monitoring (Sentry — Production Environment) ──────────────────────────────
SENTRY_DSN=https://[prod-dsn]@o[org].ingest.sentry.io/[project]
NEXT_PUBLIC_SENTRY_DSN=https://[prod-dsn]@o[org].ingest.sentry.io/[project]
SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=[prod-sentry-auth-token]

# ── Vercel Auto-Injected (do not set manually) ───────────────────────────────
# NEXT_PUBLIC_VERCEL_ENV=$VERCEL_ENV
# NEXT_PUBLIC_VERCEL_URL=$VERCEL_URL
