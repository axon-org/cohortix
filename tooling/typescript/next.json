{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Cohortix Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    // Next.js specific
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "bundler",

    // Next.js paths
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/config/*": ["./src/config/*"]
    },

    // Enable plugins
    "plugins": [
      {
        "name": "next"
      }
    ],

    // Allow JavaScript files
    "allowJs": true,
    "checkJs": false,

    // Output
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/**/*"
  ],
  "exclude": ["node_modules", ".next", "out", "dist", "build"]
}
