{
  "name": "cohortix",
  "version": "0.1.0",
  "private": true,
  "description": "Cohortix monorepo - Agent Command Center",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "turbo test:e2e",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "db:reset": "dotenv -e .env.local -- tsx scripts/reset-db.ts",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed-db.ts",
    "seed": "pnpm db:seed",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "ci:local": "pnpm lint && pnpm type-check && pnpm format:check && pnpm test && pnpm build",
    "knip": "knip",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^20.11.19",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "knip": "^5.84.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<4": ">=3.1.3",
      "minimatch@>=4 <10": ">=10.2.1",
      "minimatch@10.2.2": "10.2.3",
      "esbuild": ">=0.25.0",
      "ajv@^8": ">=8.18.0",
      "eslint": "8.57.1",
      "rollup": ">=4.59.0"
    }
  }
}
