{
  "extends": "next/core-web-vitals",
  "plugins": ["cohortix"],
  "rules": {
    "@next/next/no-html-link-for-pages": "off",
    "cohortix/no-hardcoded-colors": "warn"
  },
  "overrides": [
    {
      "files": [
        "tailwind.config.*",
        "*.config.*",
        "**/__tests__/**",
        "**/*.test.*",
        "**/*.spec.*"
      ],
      "rules": {
        "cohortix/no-hardcoded-colors": "off"
      }
    }
  ]
}
