# CODEOWNERS - Code Review Ownership
# 
# This file defines which teams/individuals are automatically requested
# for review when files in specific paths are modified.
#
# Format: <file pattern> <owner(s)>
# Owners can be:
#   - GitHub usernames: @username
#   - GitHub teams: @org/team-name
#   - Email addresses: email@example.com
#
# Rules are evaluated in order, last match takes precedence.
# More specific patterns override less specific ones.
#
# Docs: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# ═══════════════════════════════════════════════════════════════
# DEFAULT OWNERS
# These owners will be the default owners for everything in the repo.
# Unless a later match takes precedence, these will be requested.
# ═══════════════════════════════════════════════════════════════

* @platform-team


# ═══════════════════════════════════════════════════════════════
# DOCUMENTATION
# All documentation files require docs team review
# ═══════════════════════════════════════════════════════════════

/docs/ @docs-team
*.md @docs-team
/README.md @docs-team @platform-team


# ═══════════════════════════════════════════════════════════════
# FRONTEND APPLICATION
# UI/UX and frontend implementation
# ═══════════════════════════════════════════════════════════════

/apps/web/ @frontend-team
/apps/web/src/components/ @frontend-team @ui-team
/apps/web/src/app/ @frontend-team
/apps/web/src/styles/ @frontend-team @ui-team


# ═══════════════════════════════════════════════════════════════
# BACKEND & API
# Server-side logic and API routes
# ═══════════════════════════════════════════════════════════════

/apps/api/ @backend-team
/apps/web/src/app/api/ @backend-team


# ═══════════════════════════════════════════════════════════════
# DATABASE
# Schema, migrations, and database-related code
# ═══════════════════════════════════════════════════════════════

/packages/database/ @backend-team
/packages/database/migrations/ @backend-team @platform-team
/packages/database/schema/ @backend-team
