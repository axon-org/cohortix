# Cohortix — Staging Environment Variables
# ──────────────────────────────────────────
# These vars live in Vercel → Project Settings → Environment Variables
# scoped to the "Preview" environment (mapped to the `dev` branch).
#
# DO NOT commit real values. Store secrets in Vercel / GitHub Actions secrets.
# Reference this file when configuring Vercel's environment variable UI.

# ── Database (Supabase — Staging Project) ────────────────────────────────────
# Get these from: Supabase Dashboard → cohortix-staging project → Settings → Database
DATABASE_URL=postgresql://postgres.lrgjattslacqfhmqexoe:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.lrgjattslacqfhmqexoe:[password]@db.lrgjattslacqfhmqexoe.supabase.co:5432/postgres

# ── Supabase API (Staging Project) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://lrgjattslacqfhmqexoe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.[staging-anon-key]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.[staging-service-role-key]

# ── Authentication (Clerk — Staging Instance) ────────────────────────────────
# Use the STAGING Clerk application's test keys
# Get from: Clerk Dashboard → cohortix-staging app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_[staging-clerk-publishable-key]
CLERK_SECRET_KEY=sk_test_[staging-clerk-secret-key]
CLERK_WEBHOOK_SECRET=whsec_[staging-webhook-secret]

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://staging.cohortix.ai
NODE_ENV=production
BYPASS_AUTH=false

# ── Redis / Rate Limiting (Upstash — Staging DB) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://[staging-redis-endpoint].upstash.io
UPSTASH_REDIS_REST_TOKEN=[staging-redis-token]

# ── Background Jobs (Inngest — Staging Branch) ───────────────────────────────
INNGEST_EVENT_KEY=[staging-inngest-event-key]
INNGEST_SIGNING_KEY=[staging-inngest-signing-key]

# ── Monitoring (Sentry — Staging Environment) ────────────────────────────────
SENTRY_DSN=https://[staging-dsn]@o[org].ingest.sentry.io/[project]
NEXT_PUBLIC_SENTRY_DSN=https://[staging-dsn]@o[org].ingest.sentry.io/[project]
SENTRY_ENVIRONMENT=staging

# ── Vercel Auto-Injected (do not set manually) ───────────────────────────────
# NEXT_PUBLIC_VERCEL_ENV=$VERCEL_ENV
# NEXT_PUBLIC_VERCEL_URL=$VERCEL_URL
