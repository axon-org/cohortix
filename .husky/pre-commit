#!/usr/bin/env sh

pnpm exec lint-staged || exit 1

# Axon Dev Codex enforcement
STAGED_DOCS=$(git diff --cached --name-only --diff-filter=ACMRTUXB | grep -E '^(CLAUDE|CONSTITUTION)\.md$' || true)
if [ -n "$STAGED_DOCS" ]; then
  git reset -q $STAGED_DOCS
fi

# Optional: Run Axon Dev Codex hook if configured
if [ -n "$AXON_CODEX_PATH" ] && [ -f "$AXON_CODEX_PATH/hooks/pre-commit.sh" ]; then
  TODO_THRESHOLD=50 ANY_THRESHOLD=300 sh "$AXON_CODEX_PATH/hooks/pre-commit.sh"
fi
