#!/usr/bin/env sh

set -e

echo "🧹 Running lint..."
pnpm lint

echo "🧠 Running type-check..."
pnpm type-check

echo "🎨 Running format check..."
pnpm format:check

echo "✅ Pre-push checks passed."

# Optional: Run Axon Dev Codex hook if configured
if [ -n "$AXON_CODEX_PATH" ] && [ -f "$AXON_CODEX_PATH/hooks/pre-deploy.sh" ]; then
  TEST_CMD="pnpm test" BUILD_CMD="pnpm build" sh "$AXON_CODEX_PATH/hooks/pre-deploy.sh"
fi
